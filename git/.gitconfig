[user]
    # Configure in local/local.sh

[include]
    path = ~/.config/local/.gitconfig_local

[init]
    defaultBranch = main

[core]
    excludesfile = ~/.config/.gitignore_global
    ignorecase = false

[color "status"]
    added = yellow
    changed = green
    untracked = cyan
    branch = magenta

[alias]
    b = branch
    branches = branch -l
    co = checkout
    sw = switch
    c = commit
    cn = commit --no-verify
    s = status
    a = add
    pushnew = push -u origin HEAD

[branch]
    autosetupmerge = true

[commit]
	template = ~/.dotfiles/git/commit-template

[fetch]
    prune = true

[push]
    default = current

[pull]
    rebase = true

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
